<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mixer_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp">

        <!-- Bandeau marque + vumètre -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MINI MIXER"
                    android:textColor="#9FE870"
                    android:textSize="20sp"
                    android:textStyle="bold|italic"
                    android:letterSpacing="0.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="M-4 DIGITAL CONSOLE"
                    android:textColor="#6E6E78"
                    android:textSize="9sp"
                    android:letterSpacing="0.3" />
            </LinearLayout>

            <com.minimixer.app.LedMeterView
                android:id="@+id/ledMeter"
                android:layout_width="36dp"
                android:layout_height="92dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="#2E2E34" />

        <!-- Potards EQ -->
        <LinearLayout
            android:id="@+id/knobRowBig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp" />

        <!-- Potards filtres -->
        <LinearLayout
            android:id="@+id/knobRowSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="#2E2E34" />

        <TextView
            android:id="@+id/appHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6E6E78"
            android:textSize="11sp"
            android:layout_marginTop="8dp" />

        <!-- Tranches / faders -->
        <LinearLayout
            android:id="@+id/channelRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp" />

        <!-- Crossfader master -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="MASTER"
            android:textColor="#6E6E78"
            android:textSize="10sp"
            android:letterSpacing="0.3" />

        <SeekBar
            android:id="@+id/masterSeek"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="2dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:progressDrawable="@drawable/fader_track"
            android:thumb="@drawable/fader_thumb"
            android:splitTrack="false" />

        <TextView
            android:id="@+id/btnApps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:text="⚙  Activer l\'accès aux apps (notifications)"
            android:textColor="#8A8A93"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
