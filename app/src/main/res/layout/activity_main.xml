<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎛  MINI MIXER"
            android:textColor="#9FE870"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VOLUMES"
            android:textColor="#8A8A93"
            android:textSize="12sp"
            android:letterSpacing="0.2" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/panel_bg"
            android:padding="10dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/streamRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/eqTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ÉGALISEUR"
            android:textColor="#8A8A93"
            android:textSize="12sp"
            android:letterSpacing="0.2" />

        <LinearLayout
            android:id="@+id/eqRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/panel_bg"
            android:padding="10dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APPS OUVERTES"
            android:textColor="#8A8A93"
            android:textSize="12sp"
            android:letterSpacing="0.2" />

        <TextView
            android:id="@+id/appHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6E6E78"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/panel_bg"
            android:padding="10dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/appRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btnFilters"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="🎚  FILTRES"
                android:textColor="#0B0B0D"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_bg" />

            <TextView
                android:id="@+id/btnApps"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="📱  APPS"
                android:textColor="#0B0B0D"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/btn_bg" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
