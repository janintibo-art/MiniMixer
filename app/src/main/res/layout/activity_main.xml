<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mixer_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MINI MIXER"
                    android:textColor="#9FE870"
                    android:textSize="20sp"
                    android:textStyle="bold|italic"
                    android:letterSpacing="0.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="M-4 DIGITAL CONSOLE"
                    android:textColor="#6E6E78"
                    android:textSize="9sp"
                    android:letterSpacing="0.3" />

                <TextView
                    android:id="@+id/btnDual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="DUAL 🎧"
                    android:textColor="#9FE870"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:background="@drawable/dual_off" />
            </LinearLayout>

            <com.minimixer.app.LedMeterView
                android:id="@+id/ledMeter"
                android:layout_width="36dp"
                android:layout_height="92dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="#2E2E34" />

        <LinearLayout
            android:id="@+id/knobRowBig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp" />

        <LinearLayout
            android:id="@+id/knobRowSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp" />

        <LinearLayout
            android:id="@+id/presetRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="#2E2E34" />

        <TextView
            android:id="@+id/appHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6E6E78"
            android:textSize="11sp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:id="@+id/channelRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="MASTER"
            android:textColor="#6E6E78"
            android:textSize="10sp"
            android:letterSpacing="0.3" />

        <FrameLayout
            android:id="@+id/masterHolder"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="2dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/btnRefresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:layout_marginEnd="16dp"
                android:text="⟳  Rafraîchir"
                android:textColor="#9FE870"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnApps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="⚙  Accès aux apps"
                android:textColor="#8A8A93"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
